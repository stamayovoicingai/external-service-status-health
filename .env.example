# ─────────────────────────────────────────────────────────────
#  External Service Health App — configuration
#  Copy this file to `.env` (at the root) and fill in what you need.
#  To get started you do NOT need any key: the status pages are public.
# ─────────────────────────────────────────────────────────────

# Backend port
PORT=4000

# Default polling interval (seconds). Recommended minimum: 30
DEFAULT_INTERVAL_SECONDS=60

# ── Qdrant (infrastructure synthetic health check) ──────────────
# Base URL of your instance (self-hosted or Qdrant Cloud). Without this, the Qdrant monitor is disabled.
# Self-hosted e.g.:  http://localhost:6333
# Qdrant Cloud e.g.: https://xxxx-xxxx.eu-central.aws.cloud.qdrant.io:6333
QDRANT_URL=
QDRANT_API_KEY=
# Set to true to also query GET /cluster (distributed clusters only)
QDRANT_CHECK_CLUSTER=false

# ── OPTIONAL authenticated synthetic checks ─────────────────────
# If you fill these in, extra monitors are enabled that call the real API (not just the status page).

# ElevenLabs: GET https://api.elevenlabs.io/v1/models  (header xi-api-key)
ELEVENLABS_API_KEY=

# Deepgram: GET https://api.deepgram.com/v1/projects  (header Authorization: Token <key>)
DEEPGRAM_API_KEY=

# OpenAI: GET https://api.openai.com/v1/models  (header Authorization: Bearer <key>)
OPENAI_API_KEY=

# Soniox: configurable synthetic. By default NO key is used (the status page is enough).
SONIOX_API_KEY=

# ── Notifications (triggered when a service changes state) ──────
# Slack: create an "Incoming Webhook" at https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# Email (SMTP). You need the 4 SMTP_* vars + ALERT_EMAIL_TO to enable it.
# Gmail e.g.: host smtp.gmail.com, port 587, secure false, and an "App Password".
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
ALERT_EMAIL_TO=
