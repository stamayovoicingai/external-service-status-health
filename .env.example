# ─────────────────────────────────────────────────────────────
#  External Service Health App — configuración
#  Copia este archivo a `.env` (en la raíz) y rellena lo que necesites.
#  Para empezar NO necesitas ninguna key: los status pages son públicos.
# ─────────────────────────────────────────────────────────────

# Puerto del backend
PORT=4000

# Intervalo de polling por defecto (segundos). Mín. recomendado: 30
DEFAULT_INTERVAL_SECONDS=60

# ── Qdrant (synthetic health check de infraestructura) ──────────
# URL base de tu instancia (self-hosted o Qdrant Cloud). Sin esto, el monitor de Qdrant queda deshabilitado.
# Ej self-hosted:  http://localhost:6333
# Ej Qdrant Cloud: https://xxxx-xxxx.eu-central.aws.cloud.qdrant.io:6333
QDRANT_URL=
QDRANT_API_KEY=
# Pon true para consultar también GET /cluster (solo clústeres distribuidos)
QDRANT_CHECK_CLUSTER=false

# ── Synthetic checks autenticados OPCIONALES ────────────────────
# Si los rellenas, se activan monitores extra que llaman la API real (no solo el status page).

# ElevenLabs: GET https://api.elevenlabs.io/v1/models  (header xi-api-key)
ELEVENLABS_API_KEY=

# Deepgram: GET https://api.deepgram.com/v1/projects  (header Authorization: Token <key>)
DEEPGRAM_API_KEY=

# OpenAI: GET https://api.openai.com/v1/models  (header Authorization: Bearer <key>)
OPENAI_API_KEY=

# Soniox: synthetic configurable. Por defecto NO se usa key (status page basta).
SONIOX_API_KEY=

# ── Notificaciones (se disparan al cambiar de estado un servicio) ──
# Slack: crea un "Incoming Webhook" en https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# Email (SMTP). Necesitas los 4 SMTP_* + ALERT_EMAIL_TO para activarlo.
# Ej Gmail: host smtp.gmail.com, port 587, secure false, y una "App Password".
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
ALERT_EMAIL_TO=
